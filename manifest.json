

{
  "manifest_version": 3,
  "name": "Floating Browser",
  "version": "1.0",

  "permissions": [
    "storage",
    "tabs",
    "windows",
    "system.display"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "Floating Browser",
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}